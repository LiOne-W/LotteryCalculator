<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <!-- 圆角 -->
    <corners android:radius="8dp" />
    <!-- 边框 -->
    <stroke
        android:width="2dp"
        android:color="@color/lottery_yellow" />
    <!-- 背景色 -->
    <solid android:color="#33FFD740" />
    <!-- 内边距 -->
    <padding
        android:left="12dp"
        android:top="8dp"
        android:right="12dp"
        android:bottom="8dp" />
</shape>